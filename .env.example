# GiveBack Pipeline — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# Outscraper (google maps search) — you probably already have this
OUTSCRAPER_API_KEY=your_outscraper_key_here

# Gemini — free at aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# GitHub — Personal Access Token with 'repo' scope
# Get it at: github.com → Settings → Developer Settings → PAT (classic) → Generate
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username

# Optional: if deploying under a GitHub org instead of personal account
GITHUB_ORG=

# Telegram — for human-in-the-loop approval notifications
# Use an existing bot token, just create a new chat and get its ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here   # get this by sending a message and checking /getUpdates

# Pexels — free at pexels.com/api (optional, falls back to curated list)
PEXELS_API_KEY=your_pexels_key_here
